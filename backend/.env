# Database - Neon PostgreSQL
DATABASE_URL=postgresql://neondb_owner:npg_qzsoC73UxEgt@ep-shy-dawn-aimf10m1-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require

# JWT Settings - CHANGE IN PRODUCTION!
JWT_SECRET=super-secret-jwt-key-change-this-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=pocketwatch-api
JWT_AUDIENCE=pocketwatch-app

# Email Service (Resend) - For Admin Authentication
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=noreply@pocketwatch.app

# SMS Service (Twilio) - For Invitee Authentication
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# App Settings
APP_NAME=PocketWatch
APP_URL=http://localhost:3000
API_URL=http://localhost:5001

# OTP Settings
OTP_EXPIRE_MINUTES=120
OTP_LENGTH=6

# Environment
ENVIRONMENT=development
